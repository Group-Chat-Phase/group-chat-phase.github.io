<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | GROUP CHAT PHASE</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;900&family=Oswald:wght@700&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header>
    <div class="logo">
      <a href="/" style="text-decoration:none; color:white; font-weight:900; letter-spacing:-1px;">GROUP CHAT PHASE</a>
    </div>
    <nav>
  <ul>
{% for item in menu %}
  <li><a href="{{ item.url }}">{{ item.name }}</a></li>
{% endfor %}
  </ul>
</nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; 2026 GROUP CHAT PHASE. ALL RIGHTS RESERVED.</p>
  </footer>

<script>
  // 1. STORY INTERLUDES
  const interludes = document.querySelectorAll('.story-interlude');
  const interludeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const prev = entry.target.previousElementSibling;
      const next = entry.target.nextElementSibling;
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        if (prev && prev.classList.contains('story-text')) {
          prev.style.opacity = '0';
          prev.style.transition = 'opacity 0.8s ease';
        }
        if (next && next.classList.contains('story-text')) {
          next.style.opacity = '0';
          next.style.transition = 'opacity 0.8s ease';
        }
      } else {
        entry.target.classList.remove('visible');
        if (prev && prev.classList.contains('story-text')) {
          prev.style.opacity = '1';
        }
        if (next && next.classList.contains('story-text')) {
          next.style.opacity = '1';
        }
      }
    });
  }, { threshold: 0.3 });
  interludes.forEach(interlude => interludeObserver.observe(interlude));

  // 2. UNIFIED SCROLL HANDLER
  const heroImg = document.querySelector('.hero-img');
  const heroWrapper = document.querySelector('.hero-wrapper');
  const storyWrapper = document.querySelector('.story-wrapper');
  const firstStoryText = document.querySelector('.story-inner');

  // initialise first story text as invisible
  if (firstStoryText) {
    firstStoryText.style.opacity = '0';
    firstStoryText.style.transition = 'opacity 1s ease';
  }

  window.addEventListener('scroll', () => {

    // HERO IMAGE FADE IN
    if (heroImg && heroWrapper) {
      const wrapperTop = heroWrapper.getBoundingClientRect().top + window.scrollY;
      const scrollIntoWrapper = window.scrollY - wrapperTop;
      const fadeDistance = window.innerHeight * 0.8;
      const opacity = Math.max(0, Math.min(scrollIntoWrapper / fadeDistance, 1));
      heroImg.style.opacity = opacity;
    }

    // STORY TEXT FADE IN
    if (!storyWrapper || !storyInner) return;

  const wrapperTop = storyWrapper.getBoundingClientRect().top + window.scrollY;
  const scrollIntoWrapper = window.scrollY - wrapperTop;

  // Phase 1: first 100vh of scroll = pink background fades in (handled by sticky)
  // Phase 2: next 100vh = story text fades in
  const fadeStart = window.innerHeight;       // text starts fading after 1 viewport of scroll
  const fadeEnd = window.innerHeight * 2;     // fully visible after 2 viewports

  const opacity = Math.max(0, Math.min((scrollIntoWrapper - fadeStart) / (fadeEnd - fadeStart), 1));
  storyInner.style.opacity = opacity;
});
</script>
</body>
</html>
